# =========================================================================
# Blue Collar Coach Connect — environment template
# Copy to `.env` for local dev. Never commit real secrets.
# =========================================================================

# --- Core ---
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="Blue Collar Coach Connect"

# --- Database ---
# Dev: SQLite. Production (Azure SQL) example shown below.
DATABASE_URL="file:./prisma/dev.db"
# DATABASE_URL="sqlserver://your-server.database.windows.net:1433;database=bcc_connect;user=bcc_app;password=...;encrypt=true;trustServerCertificate=false"

# --- Auth (Auth.js / NextAuth v5) ---
AUTH_SECRET="generate-with: openssl rand -base64 32"
AUTH_TRUST_HOST=true
# Set DEV_AUTH_BYPASS=true to skip OAuth and sign in as a seeded local user.
DEV_AUTH_BYPASS=true

# --- Microsoft Entra ID (Azure AD) for SSO + Graph ---
# Register an app at: https://entra.microsoft.com
AUTH_MICROSOFT_ENTRA_ID=
AUTH_MICROSOFT_ENTRA_SECRET=
AUTH_MICROSOFT_ENTRA_TENANT_ID=common
# Scopes required for calendar/mail sync (space-separated)
MS_GRAPH_SCOPES="openid profile email offline_access User.Read Calendars.ReadWrite Mail.Send"

# --- QuickBooks Online (Intuit) ---
# Create app at: https://developer.intuit.com
QBO_CLIENT_ID=
QBO_CLIENT_SECRET=
QBO_REDIRECT_URI=http://localhost:3000/api/integrations/qbo/callback
QBO_ENVIRONMENT=sandbox

# --- Real-time chat (Azure SignalR or Pusher) ---
SIGNALR_CONNECTION_STRING=
# If unset, the app falls back to the in-memory mock adapter.

# --- Azure Application Insights (logging + telemetry) ---
APPLICATIONINSIGHTS_CONNECTION_STRING=
NEXT_PUBLIC_APPINSIGHTS_CONNECTION_STRING=

# --- Azure Blob Storage (documents) ---
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER_DOCS=bcc-docs

# --- Email (transactional) ---
# Use Azure Communication Services in production
ACS_CONNECTION_STRING=
EMAIL_FROM="Blue Collar Coach <no-reply@bluecollarcoach.us>"
